# Variables d'environnement pour l'authentification
# Copiez ce fichier en .env et remplissez les valeurs

# Mot de passe admin (plain text pour le développement, hashé pour la production)
ADMIN_PASSWORD=admin123

# Secret JWT pour signer les tokens d'authentification
JWT_SECRET=votre-secret-jwt-super-securise-changez-moi

# Configuration Stripe (existant)
STRIPE_SK=your-stripe-secret-key
STRIPE_PK=your-stripe-publishable-key

# Configuration Node.js
NODE_ENV=development
