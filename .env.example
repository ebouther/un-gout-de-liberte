# Variables d'environnement pour Un Goût de Liberté

# === OBLIGATOIRES ===

# Stripe (paiements)
STRIPE_PK=pk_test_... # Clé publique Stripe
STRIPE_SK=sk_test_... # Clé secrète Stripe

# Admin
ADMIN_PASSWORD=votre_mot_de_passe_admin_securise
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_minimum_32_caracteres

# === GESTION DES ARTICLES (OBLIGATOIRE pour créer des articles) ===

# GitHub (pour la synchronisation automatique des articles)
GITHUB_TOKEN=ghp_your_github_personal_access_token # Token GitHub avec permissions repo
GITHUB_REPO=ebouther/un-gout-de-liberte # Format: propriétaire/repository

# === OPTIONNELLES ===

# Host
HOST=https://un-gout-de-liberte.fr # URL de production

# === INSTRUCTIONS GITHUB TOKEN ===
# 1. Allez sur https://github.com/settings/tokens
# 2. Cliquez "Generate new token" > "Generate new token (classic)"
# 3. Donnez un nom : "Blog Articles Management"
# 4. Sélectionnez les permissions :
#    - repo (Full control of private repositories) OU public_repo (si repo public)
# 5. Copiez le token généré dans GITHUB_TOKEN

# === COMPORTEMENT ===
# Le système utilise uniquement l'API GitHub pour gérer les articles
# - Articles créés directement sur GitHub via l'API
# - Synchronisation automatique avec le repository
# - Compatible Vercel (pas d'écriture locale de fichiers)
# - Vercel redéploie automatiquement après chaque modification
